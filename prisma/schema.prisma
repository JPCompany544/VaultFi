generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Deposit {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  wallet            String
  vaultName         String    @map("vault_name")
  amountSol         Decimal   @map("amount_sol") @db.Decimal
  amountUsd         Decimal   @map("amount_usd") @db.Decimal
  sol_price         Decimal   @db.Decimal
  txHash            String    @unique @map("tx_hash")
  status            String
  apy               Decimal?  @default(0) @db.Decimal
  claimable_rewards Decimal?  @default(0) @db.Decimal
  confirmedAt       DateTime? @map("confirmed_at") @db.Timestamp(6)
  createdAt         DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updated_at        DateTime? @default(now()) @db.Timestamp(6)

  @@map("deposits")
}

model Withdrawal {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  wallet     String
  vaultName  String    @map("vault_name")
  amountUsd  Decimal   @map("amount_usd") @db.Decimal
  status     String
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  @@map("withdrawals")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model treasury_events {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_type String
  wallet     String?
  tx_hash    String?
  amount     Decimal?  @db.Decimal
  metadata   Json?
  created_at DateTime? @default(now()) @db.Timestamp(6)
}
